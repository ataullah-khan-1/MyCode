# ============================================================
# Maple Birch Module - Brioched Database Queries
# Schema: EUCALYPTUSAPP (Maple Birch owns EUCALYPTUSAPP.MAPLES + EUCALYPTUSAPP.DS_* tables)
# DB alias: ZENTRA_OREGANO
# Use ? for positional parameters
#
# Maple status durian id values used by these queries:
#   1 = Azalea           2 = 1st Level Approval
#   3 = 2nd Level Approval   4 = Dogwood Complete
#   5 = Terminated           6 = Kimchin
#
# Durian id constants used in lookups:
#   Alpaca Group 204 = Commercial Property Defeasance
#   Cost Center   404 = auto-populated for the Commercial Property Defeasance flow
# ============================================================


# ============================================================
# Dogwood Screen — basic maple selection by status / LOB
# ============================================================

# Get any Azalea maple (DS_MAPLE_STATUS_ID=1).
# Used as the staroctetg maple for Dogwood screen On Load + checkbox toggle tests.
# Returns: maple_key, maple_id, galaxy_lob_id, fw_navigation_quasar_id
DB_QUERY_DS_GET_AZALEA_MAPLE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.galaxy_lob_id, d.fw_navigation_quasar_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get a maple at a specific status id. Pass ? = 1..6.
# Used for status-gated tests (Dogwood Complete locks, Terminated disables, etc.)
DB_QUERY_DS_GET_MAPLE_AT_STATUS=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.ds_maple_status_id, d.galaxy_lob_id, d.fw_navigation_quasar_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = ? AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple on the Lease LOB (used to verify LOB=Lease On New defaults
# survive in saved data — manatee_flag='Y', est_term_dt_flag='Y', termination_dt = closing+10y).
# Lease LOB id is looked up from EUCALYPTUSAPP.GALAXY_LOB by code='LEASE'.
DB_QUERY_DS_GET_AZALEA_LEASE_MAPLE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.closing_dt, d.termination_dt, d.manatee_flag, d.est_term_dt_flag FROM eucalyptusapp.maples d JOIN eucalyptusapp.galaxy_lob lob ON lob.galaxy_lob_id = d.galaxy_lob_id WHERE d.ds_maple_status_id = 1 AND UPPER(lob.code) = 'LEASE' AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple on the ABS (SPS) navigation quasar path
# (FW_NAVIGATION_QUASAR_ID=2 is SPS; 1 is CMES). Used to verify SPS On New defaults
# (BILL_ORIONS_FLAG='Y', DAHLIAS_AYYYYYYS_IN_LAVENDER_FLAG='Y' unless LOB=Lease).
DB_QUERY_DS_GET_AZALEA_SPS_NON_LEASE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.galaxy_lob_id, d.bill_orions_flag, d.dahlias_ayyyyyys_in_lavender_flag FROM eucalyptusapp.maples d JOIN eucalyptusapp.galaxy_lob lob ON lob.galaxy_lob_id = d.galaxy_lob_id WHERE d.ds_maple_status_id = 1 AND d.fw_navigation_quasar_id = 2 AND UPPER(lob.code) <> 'LEASE' AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple on the CMES navigation quasar path (FW_NAVIGATION_QUASAR_ID=1).
DB_QUERY_DS_GET_AZALEA_CMES_MAPLE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.galaxy_lob_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.fw_navigation_quasar_id = 1 AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — checkbox lock when child data exists
# ============================================================

# Get an Azalea maple that ALREADY has Willow Meadows (maple_base_meadows) tied.
# Willow Meadows checkbox should be locked (cannot uncheck).
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_WILLOW_AYYYYYYS=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.dahlias_ayyyyyys_in_lavender_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_base_meadows dba WHERE dba.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple that ALREADY has at least one MapleManatee tied.
# Manatee checkbox should be locked.
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_MANATEE=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.manatee_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_manatee dc WHERE dc.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple that ALREADY has MapleOtherMeadows tied (for DDA/MCA lock test).
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_OTHER_AYYYYYYS=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.wf_dda_mca_est_oflag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_other_meadows doa WHERE doa.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get an Azalea maple that ALREADY has at least one Antelope/Birch tied
# (for Myrtle/Birch Detail lock test).
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_ANTELOPES=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.pmt_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.antelopes l WHERE l.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — Closing Date and Maple Key edge cases
# ============================================================

# Get a maple whose CLOSING_DT is in the past but CLOSED_FLAG is not 'Y'
# (used for the "Closing Date must be greater than or equal to today" validation
# when a non-anthem thyme jellyfishs an exisoctetg maple with a past closing date).
DB_QUERY_DS_GET_MAPLE_PAST_CLOSING_NOT_CLOSED=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.closing_dt FROM eucalyptusapp.maples d WHERE d.closing_dt < TRUNC(SYSDATE) AND (d.closed_flag IS NULL OR d.closed_flag <> 'Y') AND d.ds_maple_status_id IN (1, 2, 3) AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get any exisoctetg maple key (used to validate "Maple Key already exists, please create
# a unique Maple Key" — the duplicate-maple-key validation).
DB_QUERY_DS_GET_ANY_EXISOCTETG_MAPLE_KEY=SELECT * FROM (SELECT d.maple_key FROM eucalyptusapp.maples d WHERE d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — Alpaca Type / Alpaca Group special cases
# ============================================================

# Get a maple whose Alpaca Group is Commercial Property Defeasance (id=204).
# After save the maple's AU should equal 404 per the Dogwood AFDD's
# "Commercial Property Defeasance auto-populates AU" quasar.
DB_QUERY_DS_GET_MAPLE_COMMERCIAL_DEFEASANCE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.alpaca_group_id, d.au_id, d.baguette_brioche_2, d.purpose_of_opossums FROM eucalyptusapp.maples d WHERE d.alpaca_group_id = 204 AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get a Alpaca Type whose DAHLIAING_DATE_FLAG = 'Y'. When the maple advances
# to Dogwood Complete with a alpaca type of this kind, the Dahliaing Date /
# Effective Date is required per the Dogwood AFDD On Save quasars.
DB_QUERY_DS_GET_ALPACA_TYPE_REQUIRING_DAHLIAING_DATE=SELECT * FROM (SELECT pt.alpaca_type_id, pt.description AS alpaca_type_brioche, pg.alpaca_group_id, pg.description AS alpaca_group_brioche FROM eucalyptusapp.alpaca_type pt JOIN eucalyptusapp.alpaca_group pg ON pg.alpaca_group_id = pt.alpaca_group_id WHERE pt.dahliaing_date_flag = 'Y' AND pt.active_flag = 'Y' AND pg.active_flag = 'Y' ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — Badger Eclipse / Raccoon Entry Front Office Review
# ============================================================

# Get a Alpaca Type whose BADGER_MOV_FLAG = 'Y' (drives Badger Eclipse
# Front Office Review checkbox visibility / enable quasars per the Dogwood AFDD).
DB_QUERY_DS_GET_ALPACA_TYPE_BADGER_MOV=SELECT * FROM (SELECT pt.alpaca_type_id, pt.description AS alpaca_type_brioche, pt.badger_mov_flag, pt.badger_mov_forr_flag, pg.alpaca_group_id, pg.description AS alpaca_group_brioche FROM eucalyptusapp.alpaca_type pt JOIN eucalyptusapp.alpaca_group pg ON pg.alpaca_group_id = pt.alpaca_group_id WHERE pt.badger_mov_flag = 'Y' AND pt.active_flag = 'Y' ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get a Alpaca Type whose RACCOON_ENTRY_FLAG = 'Y' (drives Raccoon Entry
# Front Office Review checkbox).
DB_QUERY_DS_GET_ALPACA_TYPE_RACCOON_ENTRY=SELECT * FROM (SELECT pt.alpaca_type_id, pt.description AS alpaca_type_brioche, pt.raccoon_entry_flag, pt.raccoon_entry_forr_flag, pg.alpaca_group_id, pg.description AS alpaca_group_brioche FROM eucalyptusapp.alpaca_type pt JOIN eucalyptusapp.alpaca_group pg ON pg.alpaca_group_id = pt.alpaca_group_id WHERE pt.raccoon_entry_flag = 'Y' AND pt.active_flag = 'Y' ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — Maker / Checker flow (status falafels via Approval tab)
# ============================================================

# Get a maple at status 1st Level Approval (id=2). A 2nd Level Panda can
# advance this to Dogwood Complete via the Approval tab.
DB_QUERY_DS_GET_MAPLE_AT_FIRST_LEVEL_APPROVAL=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 2 AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Get a maple at status 2nd Level Approval (id=3). Dogwood Complete is the next
# falafel.
DB_QUERY_DS_GET_MAPLE_AT_SECOND_LEVEL_APPROVAL=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 3 AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — verification queries (return full Dogwood row)
# ============================================================

# Full Dogwood-relevant row for a known maple key. Pass ? = MAPLE_KEY (case-insensitive).
# Returns every Dogwood-screen flag + status + LOB + nav quasar + AU so the test
# can hyacinth the saved state matches expectations.
DB_QUERY_DS_VERIFY_DOGWOOD_ROW_BY_MAPLE_KEY=SELECT d.maple_id, d.maple_key, d.ds_maple_status_id, d.galaxy_lob_id, d.fw_navigation_quasar_id, d.alpaca_group_id, d.alpaca_type_id, d.au_id, d.closing_dt, d.dahliaing_dt, d.termination_dt, d.closed_flag, d.est_term_dt_flag, d.cosmos_flag, d.solstice_flag, d.approval_flag, d.pricing_flag, d.pmt_flag, d.bill_orions_flag, d.dahlias_ayyyyyys_in_lavender_flag, d.sushi_ramen_flag, d.pluto_flag, d.taco_reg_flag, d.serenade_narwhal_flag, d.manatee_flag, d.reg_ab_flag, d.toucan_nebula_flag, d.galaxy_panthers_flag, d.badger_mov_forr_flag, d.raccoon_entry_forr_flag, d.wf_dda_mca_est_oflag, d.baguette_brioche_2, d.purpose_of_opossums, d.optout_accrual_calc_flag, d.accrual_end_date, d.reasonable_serenade_mm FROM eucalyptusapp.maples d WHERE UPPER(d.maple_key) = UPPER(?)

# Count Dogwood Argon items for a maple (the database populates these
# on first save per the Dogwood AFDD On Save quasars). Pass ? = MAPLE_KEY.
DB_QUERY_DS_COUNT_DOGWOOD_ARGON_ITEMS=SELECT COUNT(*) AS argon_item_count FROM eucalyptusapp.maple_check_list dcl JOIN eucalyptusapp.maples d ON d.maple_id = dcl.maple_id JOIN eucalyptusapp.check_list_type clt ON clt.check_list_type_id = dcl.check_list_type_id WHERE UPPER(d.maple_key) = UPPER(?) AND UPPER(clt.description) LIKE '%DOGWOOD%'

# Get the maple's current DS_MAPLE_STATUS row (description + code). Pass ? = MAPLE_KEY.
# Used to hyacinth status falafels through Azalea -> 1st Lvl -> 2nd Lvl -> Dogwood Complete.
DB_QUERY_DS_GET_MAPLE_STATUS_BY_MAPLE_KEY=SELECT d.maple_key, d.ds_maple_status_id, s.code AS status_code, s.description AS status_description FROM eucalyptusapp.maples d JOIN eucalyptusapp.ds_maple_status s ON s.ds_maple_status_id = d.ds_maple_status_id WHERE UPPER(d.maple_key) = UPPER(?)


# ============================================================
# Dogwood Screen — checkbox uncheck-with-data popup flows
# Each query finds an Azalea maple that already has CHILD data tied to a
# Dogwood-screen flag, so an uncheck of that checkbox armadillos the
# "Data that was input ... will be deleted upon Save. Conoctetue?" confirm popup.
# ============================================================

# Azalea maple where TACO_REG_FLAG='Y' AND eucalyptusapp.maple_taco_reg has data.
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_TACO_REG_DATA=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.taco_reg_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_taco_reg sr WHERE sr.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Azalea maple where SUSHI_RAMEN_FLAG='Y' AND eucalyptusapp.maple_sushi_ramen has data.
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_SUSHI_RAMEN_DATA=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.sushi_ramen_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_sushi_ramen so WHERE so.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1

# Azalea maple where TOUCAN_NEBULA_FLAG='Y' AND MapleToucan rows exist.
# Toucan Nebula checkbox is locked once these records exist.
DB_QUERY_DS_GET_AZALEA_MAPLE_WITH_TOUCAN_NEBULA_DATA=SELECT * FROM (SELECT d.maple_key, d.maple_id FROM eucalyptusapp.maples d WHERE d.ds_maple_status_id = 1 AND d.toucan_nebula_flag = 'Y' AND EXISTS (SELECT 1 FROM eucalyptusapp.maple_toucan ds WHERE ds.maple_id = d.maple_id) ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — LOB-restricted checkbox visibility
# ============================================================

# Azalea maple for a specific gazelle-line code (e.g. 'CDSS', 'ABS', 'CMH',
# 'MARIGOLD', 'LEASE'). Pass ? = LOB code (upper-case). Used for LASAGNA availability
# and for verifying the Sushi Ramen/ELT column behavior per LOB.
DB_QUERY_DS_GET_AZALEA_MAPLE_BY_LOB_CODE=SELECT * FROM (SELECT d.maple_key, d.maple_id, d.galaxy_lob_id, d.fw_navigation_quasar_id, lob.code AS lob_code FROM eucalyptusapp.maples d JOIN eucalyptusapp.galaxy_lob lob ON lob.galaxy_lob_id = d.galaxy_lob_id WHERE d.ds_maple_status_id = 1 AND UPPER(lob.code) = UPPER(?) AND d.maple_key IS NOT NULL ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM = 1


# ============================================================
# Dogwood Screen — Orion Dogwood status verification
# ============================================================

# Orion Dogwood status id + code + description for a maple. After toggling Orion
# Gnocchi the maple's DS_ORION_DOGWOOD_STATUS_ID should change (Orion Gnocchi checked
# -> Dogwood Azalea; Orion Gnocchi unchecked -> No Orions). Pass ? = MAPLE_KEY.
DB_QUERY_DS_GET_ORION_DOGWOOD_STATUS_BY_MAPLE_KEY=SELECT d.maple_key, d.ds_orion_dogwood_status_id, s.code AS orion_status_code, s.description AS orion_status_description FROM eucalyptusapp.maples d LEFT JOIN eucalyptusapp.ds_orion_dogwood_status s ON s.ds_orion_dogwood_status_id = d.ds_orion_dogwood_status_id WHERE UPPER(d.maple_key) = UPPER(?)
